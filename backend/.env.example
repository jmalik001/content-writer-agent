# ─── LLM Provider ───────────────────────────────────────────────────────────
# Select provider: "groq" (free, fast) or "openai"
LLM_PROVIDER=groq

# Groq API key — get free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API key — only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# Override default model (optional)
# Groq default: llama3-8b-8192
# OpenAI default: gpt-4o-mini
LLM_MODEL=

# ─── Web Search ─────────────────────────────────────────────────────────────
# Tavily API key — optional, falls back to DuckDuckGo (no key needed)
# Get free key at https://tavily.com
TAVILY_API_KEY=

# ─── LangSmith Tracing (optional) ───────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=linkedin-content-writer

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Allowed frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:3000
